.detail-page {
  padding-bottom: 150rpx;
  background: linear-gradient(180deg, #fff2e2 0%, #fffaf4 48%, #f7fbf3 100%);
}

.detail-card,
.safe-panel,
.comment-panel,
.missing-card {
  padding: 30rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(118, 82, 55, 0.07);
}

.meetup-card.food {
  border-color: #f3caa6;
  background: #fff3e6;
}

.meetup-card.sport {
  border-color: #b8d8d1;
  background: #eef9f6;
}

.meetup-card.mahjong {
  border-color: #dfe9bf;
  background: #fbfbea;
}

.meetup-card.walk {
  border-color: #cfd8f3;
  background: #f2f5ff;
}

.meetup-card.movie {
  border-color: #eadcf8;
  background: #fbf4ff;
}

.meetup-head,
.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meetup-tag,
.meetup-status {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 800;
}

.meetup-tag {
  color: #b65f2a;
}

.meetup-status {
  color: #7d6252;
}

.meetup-title {
  display: block;
  margin-top: 20rpx;
  color: #3a2a22;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.meetup-desc {
  display: block;
  margin-top: 12rpx;
  color: #725e52;
  font-size: 27rpx;
  line-height: 1.55;
}

.meetup-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.meetup-meta text {
  min-height: 48rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  color: #5f4b3f;
  background: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  font-weight: 800;
}

.meetup-author {
  display: block;
  margin-top: 18rpx;
  color: #8a7467;
  font-size: 24rpx;
}

.join-button {
  height: 76rpx;
  margin-top: 22rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf4;
  background: #b65f2a;
  font-size: 27rpx;
  font-weight: 800;
}

.detail-action-row {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.detail-action-row .join-button {
  flex: 1;
  margin-top: 0;
}

.cancel-button {
  flex: 0 0 172rpx;
  height: 76rpx;
  border-radius: 8rpx;
  color: #7d6252;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.join-button.joined {
  color: #627a35;
  background: #dfe9bf;
}

.safe-panel,
.comment-panel {
  margin-top: 22rpx;
}

.safe-panel {
  background: #fff7ec;
  border-color: #f3caa6;
}

.safe-title {
  display: block;
  color: #3a2a22;
  font-size: 30rpx;
  font-weight: 800;
}

.safe-desc {
  display: block;
  margin-top: 10rpx;
  color: #765544;
  font-size: 25rpx;
  line-height: 1.55;
}

.comment-head {
  color: #8a7467;
  font-size: 23rpx;
  font-weight: 800;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.comment-item {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 14rpx;
  border-radius: 8rpx;
  background: #fffaf4;
  font-size: 24rpx;
  line-height: 1.45;
}

.comment-author {
  color: #7d4b30;
  font-weight: 800;
}

.comment-text {
  flex: 1;
  min-width: 260rpx;
  color: #5f4b3f;
}

.comment-time {
  color: #9b8475;
  font-size: 22rpx;
}

.comment-empty {
  margin-top: 16rpx;
  color: #8a7467;
  font-size: 25rpx;
}

.comment-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 250, 244, 0.98);
  border-top: 2rpx solid rgba(234, 217, 201, 0.9);
  display: flex;
  gap: 12rpx;
  box-sizing: border-box;
}

.comment-input {
  flex: 1;
  height: 70rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: #ffffff;
  border: 2rpx solid rgba(234, 217, 201, 0.84);
  font-size: 24rpx;
}

.comment-button {
  flex: 0 0 112rpx;
  height: 70rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf4;
  background: #3f6f64;
  font-size: 24rpx;
  font-weight: 800;
}
