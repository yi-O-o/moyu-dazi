.offwork-page {
  padding-bottom: 72rpx;
  background: linear-gradient(180deg, #fff2e2 0%, #fffaf4 48%, #f7fbf3 100%);
}

.off-hero {
  min-height: 320rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
  padding: 38rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: linear-gradient(135deg, #ffe6cc 0%, #f4b183 52%, #dfe9bf 100%);
  box-shadow: 0 24rpx 58rpx rgba(194, 105, 48, 0.16);
}

.warm-light {
  color: #b65f2a;
}

.off-title {
  display: block;
  max-width: 500rpx;
  font-size: 48rpx;
  line-height: 1.18;
  font-weight: 800;
}

.off-subtitle {
  display: block;
  margin-top: 18rpx;
  max-width: 520rpx;
  color: #7d6252;
  font-size: 27rpx;
  line-height: 1.55;
}

.publish-button {
  flex: 0 0 auto;
  height: 72rpx;
  min-width: 132rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #fffaf4;
  background: #b65f2a;
  font-size: 26rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 28rpx rgba(146, 75, 34, 0.2);
}

.type-scroll {
  margin-top: 24rpx;
  width: 100%;
  white-space: nowrap;
}

.type-row {
  display: flex;
  gap: 12rpx;
  padding-right: 18rpx;
}

.type-chip {
  flex: 0 0 auto;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #765544;
  background: rgba(255, 253, 249, 0.9);
  border: 2rpx solid rgba(234, 217, 201, 0.8);
  font-size: 25rpx;
  font-weight: 800;
}

.type-chip.active {
  color: #fffaf4;
  background: #3f6f64;
  border-color: #3f6f64;
}

.publish-modal {
  position: fixed;
  inset: 0;
  z-index: 60;
}

.publish-mask {
  position: absolute;
  inset: 0;
  background: rgba(45, 37, 32, 0.32);
}

.publish-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 82vh;
  overflow-y: auto;
  padding: 28rpx;
  padding-bottom: calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 8rpx;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.97);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 -18rpx 48rpx rgba(45, 37, 32, 0.14);
}

.sheet-handle {
  width: 74rpx;
  height: 8rpx;
  margin: 0 auto 20rpx;
  border-radius: 8rpx;
  background: #d7c5b4;
}

.publish-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.publish-title {
  color: #3a2a22;
  font-size: 31rpx;
  font-weight: 800;
}

.publish-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
  color: #8a7467;
  background: #fff0dc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
}

.publish-type-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.publish-type {
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #765544;
  background: #fff7ee;
  border: 2rpx solid rgba(234, 217, 201, 0.8);
  font-size: 24rpx;
  font-weight: 800;
}

.publish-type.selected {
  color: #fffaf4;
  background: #b65f2a;
  border-color: #b65f2a;
}

.meetup-input,
.meetup-textarea {
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: #fffaf4;
  border: 2rpx solid rgba(234, 217, 201, 0.88);
  font-size: 26rpx;
}

.meetup-input {
  height: 78rpx;
}

.meetup-textarea {
  min-height: 144rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.form-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 160rpx;
  gap: 14rpx;
}

.meetup-input.half {
  min-width: 0;
}

.safe-tip {
  display: block;
  margin-top: 14rpx;
  color: #8a7467;
  font-size: 23rpx;
  line-height: 1.5;
}

.submit-meetup {
  height: 76rpx;
  margin-top: 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf4;
  background: #3f6f64;
  font-size: 27rpx;
  font-weight: 800;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 32rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #3a2a22;
  font-size: 33rpx;
  font-weight: 800;
}

.section-action {
  flex: 0 0 auto;
  color: #7d6252;
  font-size: 23rpx;
  font-weight: 700;
}

.meetup-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-meetup {
  padding: 34rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.95);
  border: 2rpx dashed rgba(182, 95, 42, 0.28);
}

.empty-title {
  display: block;
  color: #3a2a22;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a7467;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-button {
  width: 150rpx;
  height: 62rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf4;
  background: #b65f2a;
  font-size: 25rpx;
  font-weight: 800;
}

.meetup-card {
  display: block;
  padding: 28rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 15rpx 36rpx rgba(118, 82, 55, 0.07);
}

.meetup-card.food {
  border-color: #f3caa6;
  background: #fff3e6;
}

.meetup-card.sport {
  border-color: #b8d8d1;
  background: #eef9f6;
}

.meetup-card.mahjong {
  border-color: #dfe9bf;
  background: #fbfbea;
}

.meetup-card.walk {
  border-color: #cfd8f3;
  background: #f2f5ff;
}

.meetup-card.movie {
  border-color: #eadcf8;
  background: #fbf4ff;
}

.meetup-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.meetup-tag,
.meetup-status {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 800;
}

.meetup-tag {
  color: #b65f2a;
}

.sport .meetup-tag {
  color: #3f6f64;
}

.mahjong .meetup-tag {
  color: #6f8d44;
}

.walk .meetup-tag,
.movie .meetup-tag {
  color: #5f6aa8;
}

.meetup-status {
  flex: 0 0 auto;
  color: #7d6252;
}

.meetup-title {
  display: block;
  margin-top: 16rpx;
  color: #3a2a22;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.meetup-desc {
  display: block;
  margin-top: 8rpx;
  color: #725e52;
  font-size: 25rpx;
  line-height: 1.5;
}

.meetup-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.meetup-meta text {
  min-height: 46rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  color: #5f4b3f;
  background: rgba(255, 255, 255, 0.68);
  font-size: 23rpx;
  font-weight: 700;
}

.meetup-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.meetup-author {
  flex: 1;
  min-width: 0;
  color: #8a7467;
  font-size: 23rpx;
  line-height: 1.45;
}

.join-button,
.detail-button {
  flex: 0 0 auto;
  min-width: 132rpx;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #fffaf4;
  background: #b65f2a;
  font-size: 25rpx;
  font-weight: 800;
}

.detail-button {
  min-width: 104rpx;
  color: #b65f2a;
  background: rgba(255, 255, 255, 0.72);
}

.join-button.joined {
  color: #627a35;
  background: #dfe9bf;
}

.meetup-comments {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.76);
}

.comment-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #8a7467;
  font-size: 22rpx;
  font-weight: 800;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 12rpx;
}

.comment-item {
  display: flex;
  gap: 10rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.58);
  font-size: 23rpx;
  line-height: 1.45;
}

.comment-author {
  flex: 0 0 auto;
  color: #7d4b30;
  font-weight: 800;
}

.comment-text {
  flex: 1;
  min-width: 0;
  color: #5f4b3f;
}

.comment-empty {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  color: #8a7467;
  background: rgba(255, 255, 255, 0.5);
  font-size: 23rpx;
}

.comment-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.comment-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: rgba(255, 250, 244, 0.92);
  border: 2rpx solid rgba(234, 217, 201, 0.84);
  font-size: 24rpx;
}

.comment-button {
  flex: 0 0 104rpx;
  height: 64rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf4;
  background: #3f6f64;
  font-size: 24rpx;
  font-weight: 800;
}

.song-preview {
  margin-top: 28rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  color: #3a2a22;
  background: linear-gradient(135deg, #fff0dc 0%, #eadcf8 52%, #dfe9bf 100%);
  box-shadow: 0 18rpx 42rpx rgba(118, 82, 55, 0.08);
}

.song-kicker {
  display: block;
  color: #8c5a3d;
  font-size: 23rpx;
  font-weight: 800;
}

.song-title {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.song-desc {
  display: block;
  margin-top: 10rpx;
  color: #6b5a50;
  font-size: 26rpx;
  line-height: 1.55;
}
