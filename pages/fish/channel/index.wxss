.channel-page {
  padding-bottom: 72rpx;
}

.channel-hero {
  min-height: 286rpx;
  padding: 36rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: linear-gradient(135deg, #fff0dc 0%, #dfe9bf 58%, #eef9f6 100%);
  box-shadow: 0 24rpx 58rpx rgba(118, 82, 55, 0.12);
}

.warm {
  color: #b65f2a;
}

.channel-title {
  display: block;
  font-size: 52rpx;
  line-height: 1.14;
  font-weight: 800;
}

.channel-desc {
  display: block;
  margin-top: 14rpx;
  color: #6b5a50;
  font-size: 27rpx;
  line-height: 1.5;
}

.channel-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.channel-stats text {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  color: #7d4b30;
  background: rgba(255, 253, 249, 0.76);
  font-size: 22rpx;
  font-weight: 800;
}

.template-panel,
.tag-panel,
.post-card,
.empty-channel {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(118, 82, 55, 0.07);
}

.panel-head,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.panel-title,
.section-title {
  color: #3a2a22;
  font-size: 31rpx;
  font-weight: 800;
}

.publish-entry {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  color: #fffaf4;
  background: #b65f2a;
  font-size: 23rpx;
  font-weight: 800;
}

.prompt-row,
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.prompt-chip {
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  color: #7d4b30;
  background: #fff0dc;
  font-size: 24rpx;
  font-weight: 800;
}

.safe-tip {
  display: block;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  color: #765544;
  background: #fff7ec;
  font-size: 24rpx;
  line-height: 1.5;
}

.hot-tag,
.post-tag {
  color: #b65f2a;
  font-size: 24rpx;
  font-weight: 800;
}

.section-head {
  margin-top: 32rpx;
}

.section-action {
  flex: 0 0 auto;
  color: #9b8475;
  font-size: 22rpx;
  font-weight: 700;
}

.empty-channel {
  text-align: center;
}

.empty-title {
  display: block;
  color: #3a2a22;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a7467;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-button {
  width: 180rpx;
  height: 70rpx;
  margin: 20rpx auto 0;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.post-author {
  display: block;
  color: #3a2a22;
  font-size: 26rpx;
  font-weight: 800;
}

.post-meta {
  display: block;
  margin-top: 4rpx;
  color: #9b8475;
  font-size: 22rpx;
}

.post-title {
  display: block;
  margin-top: 20rpx;
  color: #3a2a22;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.post-content {
  display: block;
  margin-top: 10rpx;
  color: #5f4b3f;
  font-size: 26rpx;
  line-height: 1.55;
}

.post-foot {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.post-foot text {
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  color: #7d6252;
  background: #fff7ec;
  font-size: 22rpx;
  font-weight: 800;
}
