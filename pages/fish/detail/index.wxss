.detail-page {
  padding-bottom: 140rpx;
}

.detail-card,
.comment-panel,
.missing-card {
  padding: 30rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(118, 82, 55, 0.07);
}

.comment-panel {
  margin-top: 22rpx;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar,
.comment-avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.post-author,
.comment-author {
  display: block;
  color: #3a2a22;
  font-size: 26rpx;
  font-weight: 800;
}

.post-meta {
  display: block;
  margin-top: 4rpx;
  color: #9b8475;
  font-size: 22rpx;
}

.post-more {
  margin-left: auto;
  color: #b9a69a;
  font-size: 32rpx;
  font-weight: 800;
}

.detail-title {
  display: block;
  margin-top: 24rpx;
  color: #3a2a22;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 800;
}

.detail-content {
  display: block;
  margin-top: 14rpx;
  color: #5f4b3f;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 22rpx;
}

.detail-images.image-count-1 {
  grid-template-columns: 1fr;
}

.detail-image {
  width: 100%;
  height: 190rpx;
  border-radius: 8rpx;
  background: #f2e4d6;
}

.image-count-1 .detail-image {
  height: 420rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.post-tag {
  color: #b65f2a;
  font-size: 23rpx;
  font-weight: 800;
}

.post-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.post-action {
  height: 62rpx;
  border-radius: 8rpx;
  background: #fff7ec;
  color: #7d6252;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 800;
}

.post-action.active {
  background: #fff0dc;
  color: #b65f2a;
}

.panel-title {
  display: block;
  color: #3a2a22;
  font-size: 31rpx;
  font-weight: 800;
}

.comment-list {
  margin-top: 20rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #f2e4d6;
}

.comment-item:last-child {
  border-bottom: 0;
}

.comment-content {
  display: block;
  margin-top: 6rpx;
  color: #6b5a50;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-comment {
  margin-top: 18rpx;
  color: #8a7467;
  font-size: 25rpx;
}

.comment-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(255, 253, 249, 0.98);
  border-top: 2rpx solid rgba(234, 217, 201, 0.9);
  display: flex;
  gap: 12rpx;
  box-sizing: border-box;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: #fffaf3;
  border: 2rpx solid #ead9c9;
  color: #3a2a22;
  font-size: 25rpx;
  box-sizing: border-box;
}

.comment-submit {
  width: 104rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background: #8fbf78;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.missing-card {
  color: #8a7467;
  font-size: 28rpx;
}
