.fish-page {
  padding-bottom: 72rpx;
}

.fish-hero {
  min-height: 300rpx;
  padding: 36rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: linear-gradient(135deg, #fff0dc 0%, #f7d4b6 50%, #dfe9bf 100%);
  box-shadow: 0 24rpx 58rpx rgba(177, 112, 62, 0.16);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24rpx;
}

.light {
  color: #b65f2a;
}

.fish-title {
  display: block;
  font-size: 50rpx;
  line-height: 1.18;
  font-weight: 800;
}

.fish-subtitle {
  display: block;
  max-width: 470rpx;
  margin-top: 14rpx;
  color: #7d6252;
  font-size: 26rpx;
  line-height: 1.5;
}

.fish-exp {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 9rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.72);
  color: #8c5a3d;
  font-size: 22rpx;
  font-weight: 800;
}

.publish-button {
  flex: 0 0 auto;
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.channel-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.channel-row {
  display: flex;
  gap: 12rpx;
}

.channel-chip {
  flex: 0 0 auto;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  color: #7d6252;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 800;
}

.channel-chip.active {
  background: #fff0dc;
  border-color: #f3caa6;
  color: #b65f2a;
}

.channel-desc {
  display: block;
  margin-top: 12rpx;
  color: #8a7467;
  font-size: 24rpx;
}

.publish-panel,
.post-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(118, 82, 55, 0.07);
}

.publish-title {
  display: block;
  color: #3a2a22;
  font-size: 31rpx;
  font-weight: 800;
}

.publish-channel-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.publish-channel {
  padding: 9rpx 15rpx;
  border-radius: 8rpx;
  background: #fff7ec;
  border: 2rpx solid #f3caa6;
  color: #7d6252;
  font-size: 23rpx;
  font-weight: 800;
}

.publish-channel.selected {
  background: #b65f2a;
  color: #ffffff;
  border-color: #b65f2a;
}

.pond-input,
.pond-textarea {
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: #fffaf3;
  border: 2rpx solid #ead9c9;
  color: #3a2a22;
  font-size: 25rpx;
}

.pond-input {
  height: 76rpx;
}

.pond-textarea {
  height: 150rpx;
  padding-top: 18rpx;
}

.safe-tip {
  display: block;
  margin-top: 14rpx;
  color: #9b8475;
  font-size: 22rpx;
  line-height: 1.45;
}

.image-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.picked-image-wrap,
.add-image {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #fff7ec;
  border: 2rpx solid #ead9c9;
  box-sizing: border-box;
}

.picked-image {
  width: 100%;
  height: 100%;
}

.remove-image {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(58, 42, 34, 0.68);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.add-image {
  border-style: dashed;
  color: #b65f2a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.submit-post {
  height: 78rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.post-list {
  margin-top: 4rpx;
}

.empty-pond {
  margin-top: 22rpx;
  padding: 34rpx 28rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx dashed rgba(234, 217, 201, 0.98);
  text-align: center;
}

.empty-title {
  display: block;
  color: #3a2a22;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-desc {
  display: block;
  margin-top: 10rpx;
  color: #8a7467;
  font-size: 25rpx;
  line-height: 1.5;
}

.empty-button {
  width: 180rpx;
  height: 70rpx;
  margin: 20rpx auto 0;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.post-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 58rpx;
  height: 58rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.post-author {
  display: block;
  color: #3a2a22;
  font-size: 26rpx;
  font-weight: 800;
}

.post-meta {
  display: block;
  margin-top: 4rpx;
  color: #9b8475;
  font-size: 22rpx;
}

.post-more {
  margin-left: auto;
  color: #b9a69a;
  font-size: 32rpx;
  font-weight: 800;
}

.post-title {
  display: block;
  margin-top: 20rpx;
  color: #3a2a22;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.post-content {
  display: block;
  margin-top: 10rpx;
  color: #5f4b3f;
  font-size: 26rpx;
  line-height: 1.55;
}

.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.post-images.image-count-1 {
  grid-template-columns: 1fr;
}

.post-image {
  width: 100%;
  height: 156rpx;
  border-radius: 8rpx;
  background: #f2e4d6;
}

.image-count-1 .post-image {
  height: 360rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.post-tag {
  color: #b65f2a;
  font-size: 23rpx;
  font-weight: 800;
}

.post-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 20rpx;
}

.post-action {
  height: 58rpx;
  border-radius: 8rpx;
  background: #fff7ec;
  color: #7d6252;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}

.post-action.active {
  background: #fff0dc;
  color: #b65f2a;
}

.comment-list {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #fffaf3;
}

.comment-item {
  display: flex;
  gap: 8rpx;
  color: #6b5a50;
  font-size: 23rpx;
  line-height: 1.45;
}

.comment-item + .comment-item {
  margin-top: 8rpx;
}

.comment-author {
  flex: 0 0 auto;
  color: #b65f2a;
  font-weight: 800;
}

.comment-box {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.comment-input {
  flex: 1;
  height: 66rpx;
  padding: 0 18rpx;
  border-radius: 8rpx;
  background: #fffaf3;
  border: 2rpx solid #ead9c9;
  color: #3a2a22;
  font-size: 24rpx;
  box-sizing: border-box;
}

.comment-submit {
  width: 92rpx;
  height: 66rpx;
  border-radius: 8rpx;
  background: #8fbf78;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}
