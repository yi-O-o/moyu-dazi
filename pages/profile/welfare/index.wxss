.welfare-page {
  padding-bottom: 72rpx;
}

.welfare-hero {
  padding: 36rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: linear-gradient(135deg, #fff0dc 0%, #dfe9bf 52%, #eef9f6 100%);
  box-shadow: 0 24rpx 58rpx rgba(118, 82, 55, 0.12);
}

.warm {
  color: #b65f2a;
}

.welfare-title {
  display: block;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.welfare-desc {
  display: block;
  margin-top: 16rpx;
  color: #6b5a50;
  font-size: 26rpx;
  line-height: 1.55;
}

.level-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  color: #7d4b30;
  background: rgba(255, 253, 249, 0.72);
  font-size: 24rpx;
  font-weight: 800;
}

.rule-list,
.reward-list,
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rule-card,
.reward-row,
.record-row,
.appeal-panel,
.safe-panel {
  padding: 26rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 14rpx 34rpx rgba(118, 82, 55, 0.06);
}

.rule-title,
.reward-title,
.record-title,
.safe-title {
  display: block;
  color: #3a2a22;
  font-size: 29rpx;
  font-weight: 800;
}

.rule-desc,
.reward-desc,
.record-desc,
.safe-desc {
  display: block;
  margin-top: 10rpx;
  color: #7d6252;
  font-size: 25rpx;
  line-height: 1.5;
}

.reward-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.record-status {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  color: #4f7f52;
  background: #eef6df;
  font-size: 22rpx;
  font-weight: 800;
}

.reward-row.unlocked {
  border-color: #dfe9bf;
  background: linear-gradient(135deg, #fffaf3 0%, #f7fbe8 100%);
}

.reward-row.locked {
  opacity: 0.72;
}

.reward-status {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  color: #b65f2a;
  background: #fff0dc;
  font-size: 22rpx;
  font-weight: 800;
}

.appeal-panel {
  background: #fffaf3;
}

.appeal-input {
  width: 100%;
  min-height: 160rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ead9c9;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.96);
  color: #3a2a22;
  font-size: 26rpx;
  line-height: 1.45;
}

.appeal-button {
  height: 74rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.safe-panel {
  margin-top: 28rpx;
  border-color: #f3caa6;
  background: #fff7ec;
}
