<view class="page welfare-page">
  <view class="welfare-hero">
    <text class="eyebrow warm">宠物福利池</text>
    <text class="welfare-title">攒分不是提现，是获得参与资格</text>
    <text class="welfare-desc">福利池适合后期做奶茶券、运动券、会员券和小额红包活动。规则先写清楚，用户预期就不会跑偏。</text>
    <view class="level-card">
      <text>当前 Lv.{{game.level.level}} {{game.level.title}}</text>
      <text>{{game.points}} 分</text>
    </view>
  </view>

  <view class="section-title">基础规则</view>
  <view class="rule-list">
    <view class="rule-card" wx:for="{{rules}}" wx:key="title">
      <text class="rule-title">{{item.title}}</text>
      <text class="rule-desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="section-title">等级福利</view>
  <view class="reward-list">
    <view class="{{item.className}}" wx:for="{{rewards}}" wx:key="title">
      <view>
        <text class="reward-title">{{item.title}}</text>
        <text class="reward-desc">{{item.desc}}</text>
      </view>
      <text class="reward-status">{{item.statusText}}</text>
    </view>
  </view>

  <view class="section-title">活动记录</view>
  <view class="record-list">
    <view class="record-row" wx:for="{{records}}" wx:key="id">
      <view>
        <text class="record-title">{{item.title}}</text>
        <text class="record-desc">{{item.desc}}</text>
      </view>
      <text class="record-status">{{item.status}}</text>
    </view>
  </view>

  <view class="section-title">申诉入口</view>
  <view class="appeal-panel">
    <textarea class="appeal-input" maxlength="120" placeholder="如果积分、资格或奖励记录有问题，可以简单说明情况。" value="{{appealInput}}" bindinput="handleAppealInput"></textarea>
    <view class="appeal-button" bindtap="submitAppeal">提交申诉</view>
  </view>

  <view class="safe-panel">
    <text class="safe-title">上线前必须补齐</text>
    <text class="safe-desc">隐私协议、预算上限、开奖/发放记录、反作弊策略和后台申诉处理流。</text>
  </view>
</view>
