.profile-page {
  padding-bottom: 72rpx;
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 34rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #fff0dc 0%, #f7d4b6 54%, #dfe9bf 100%);
  color: #3a2a22;
  box-shadow: 0 22rpx 54rpx rgba(177, 112, 62, 0.16);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 34rpx;
}

.profile-head .eyebrow {
  color: #b65f2a;
  margin-bottom: 6rpx;
}

.name {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
}

.desc {
  display: block;
  margin-top: 8rpx;
  color: #7d6252;
  font-size: 25rpx;
  line-height: 1.45;
}

.list {
  padding: 0;
}

.list-row {
  min-height: 92rpx;
  padding: 0 28rpx;
  border-bottom: 2rpx solid #f2e4d6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #3a2a22;
}

.list-row:last-child {
  border-bottom: 0;
}

.strong {
  color: #b65f2a;
  font-weight: 800;
}

.pet-status {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.pet-badge {
  width: 84rpx;
  height: 84rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.pet-name,
.booking-title {
  display: block;
  color: #3a2a22;
  font-size: 30rpx;
  font-weight: 800;
}

.pet-info,
.booking-desc {
  display: block;
  margin-top: 8rpx;
  color: #8a7467;
  font-size: 25rpx;
  line-height: 1.5;
}

.booking {
  background: #fff3e6;
  border-color: #f3caa6;
}

.pond-panel {
  padding: 0;
  overflow: hidden;
}

.pond-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: #fff7ec;
  border-bottom: 2rpx solid #f2e4d6;
}

.pond-stats > view {
  min-height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.pond-stat-value {
  color: #b65f2a;
  font-size: 34rpx;
  font-weight: 800;
}

.pond-stat-label {
  color: #8a7467;
  font-size: 22rpx;
  font-weight: 800;
}

.pond-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 20rpx;
}

.pond-tab {
  height: 64rpx;
  border-radius: 8rpx;
  background: #fffaf3;
  color: #7d6252;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.pond-tab.active {
  background: #fff0dc;
  color: #b65f2a;
}

.pond-empty {
  padding: 18rpx 24rpx 30rpx;
  color: #8a7467;
  font-size: 25rpx;
  line-height: 1.5;
}

.pond-item {
  min-height: 104rpx;
  padding: 18rpx 24rpx;
  border-top: 2rpx solid #f2e4d6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.pond-item-title {
  display: block;
  color: #3a2a22;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.pond-item-meta {
  display: block;
  margin-top: 7rpx;
  color: #9b8475;
  font-size: 22rpx;
  line-height: 1.35;
}

.pond-item-arrow {
  flex: 0 0 auto;
  color: #b9a69a;
  font-size: 42rpx;
}

.badge-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.badge-card {
  min-height: 170rpx;
  padding: 20rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 12rpx 30rpx rgba(118, 82, 55, 0.05);
  text-align: center;
  box-sizing: border-box;
}

.badge-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin: 0 auto 12rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  font-size: 24rpx;
  font-weight: 800;
}

.badge-title {
  display: block;
  color: #3a2a22;
  font-size: 24rpx;
  font-weight: 800;
}

.badge-desc {
  display: block;
  margin-top: 8rpx;
  color: #8a7467;
  font-size: 21rpx;
  line-height: 1.35;
}

.future-card {
  margin-top: 30rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  color: #3a2a22;
  background: linear-gradient(135deg, #fff0dc 0%, #eadcf8 52%, #dfe9bf 100%);
  box-shadow: 0 18rpx 42rpx rgba(118, 82, 55, 0.08);
}

.future-kicker {
  display: block;
  color: #8c5a3d;
  font-size: 23rpx;
  font-weight: 800;
}

.future-title {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.future-desc {
  display: block;
  margin-top: 10rpx;
  color: #6b5a50;
  font-size: 26rpx;
  line-height: 1.55;
}
