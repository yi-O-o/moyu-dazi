.profile-page {
  padding-bottom: 72rpx;
}

.profile-head {
  display: grid;
  grid-template-columns: 118rpx minmax(0, 1fr);
  column-gap: 24rpx;
  align-items: center;
  padding: 32rpx 30rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #fff5e8 0%, #f8ddc4 48%, #edf3d0 100%);
  color: #3a2a22;
  box-shadow: 0 18rpx 42rpx rgba(118, 82, 55, 0.12);
}

.avatar-stack {
  position: relative;
  width: 104rpx;
  justify-self: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  margin: 0;
  padding: 0;
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 104rpx;
  min-width: 104rpx;
  min-height: 104rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  background: #fffdf9;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #b65f2a;
  font-weight: 800;
  font-size: 38rpx;
  line-height: 104rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 26rpx rgba(118, 82, 55, 0.14);
}

.avatar-button {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-button::after {
  border: 0;
}

.avatar-image {
  flex: 0 0 96rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 6rpx;
  display: block;
}

.avatar-tip {
  position: absolute;
  right: -2rpx;
  bottom: -2rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 8rpx;
  background: #b65f2a;
  border: 3rpx solid #fffdf9;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.profile-info {
  min-width: 0;
  width: 100%;
}

.profile-head .eyebrow {
  color: #b65f2a;
  margin-bottom: 6rpx;
}

.name-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.name-editor {
  flex: 1;
  min-width: 0;
  min-height: 60rpx;
  padding: 0 6rpx 0 0;
  border-radius: 8rpx;
  background: transparent;
  border-bottom: 3rpx solid rgba(182, 95, 42, 0.22);
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.name-edit-mark {
  flex: 0 0 auto;
  color: #b65f2a;
  font-size: 23rpx;
  font-weight: 800;
  padding: 8rpx 0 8rpx 12rpx;
}

.name-input {
  flex: 1;
  width: 100%;
  min-height: 58rpx;
  padding: 0;
  color: #3a2a22;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.status-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.status-badge {
  max-width: 360rpx;
  min-height: 46rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.78);
  border: 2rpx solid rgba(111, 159, 114, 0.32);
  color: #4f7f52;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.status-badge text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
  font-weight: 800;
}

.status-empty {
  color: #9b8475;
  font-size: 22rpx;
  font-weight: 700;
}

.desc {
  display: block;
  margin-top: 10rpx;
  color: #7d6252;
  font-size: 25rpx;
  line-height: 1.45;
}

.list {
  padding: 0;
}

.list-row {
  min-height: 92rpx;
  padding: 0 28rpx;
  border-bottom: 2rpx solid #f2e4d6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #3a2a22;
}

.list-row:last-child {
  border-bottom: 0;
}

.strong {
  color: #b65f2a;
  font-weight: 800;
}

.pet-status {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.pet-badge {
  width: 84rpx;
  height: 84rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.pet-name,
.booking-title {
  display: block;
  color: #3a2a22;
  font-size: 30rpx;
  font-weight: 800;
}

.pet-info,
.booking-desc {
  display: block;
  margin-top: 8rpx;
  color: #8a7467;
  font-size: 25rpx;
  line-height: 1.5;
}

.booking {
  background: #fff3e6;
  border-color: #f3caa6;
}

.meetup-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.meetup-tab {
  height: 62rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.82);
  color: #7d6252;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 800;
}

.meetup-tab.active {
  color: #ffffff;
  background: #3f6f64;
  border-color: #3f6f64;
}

.meetup-list-mini {
  overflow: hidden;
  border: 2rpx solid rgba(234, 217, 201, 0.82);
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  box-shadow: 0 18rpx 42rpx rgba(118, 82, 55, 0.08);
}

.meetup-mini {
  min-height: 104rpx;
  padding: 18rpx 24rpx;
  border-bottom: 2rpx solid #f2e4d6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.meetup-mini:last-child {
  border-bottom: 0;
}

.meetup-mini-title {
  display: block;
  color: #3a2a22;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.meetup-mini-meta {
  display: block;
  margin-top: 7rpx;
  color: #9b8475;
  font-size: 22rpx;
  line-height: 1.35;
}

.meetup-mini-status {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  color: #b65f2a;
  background: #fff0dc;
  font-size: 22rpx;
  font-weight: 800;
}

.meetup-mini-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.meetup-mini-cancel {
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  color: #7d6252;
  background: #fff7ec;
  font-size: 22rpx;
  font-weight: 800;
}

.pond-panel {
  padding: 0;
  overflow: hidden;
}

.pond-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: #fff7ec;
  border-bottom: 2rpx solid #f2e4d6;
}

.pond-stats > view {
  min-height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.pond-stat-value {
  color: #b65f2a;
  font-size: 34rpx;
  font-weight: 800;
}

.pond-stat-label {
  color: #8a7467;
  font-size: 22rpx;
  font-weight: 800;
}

.pond-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 20rpx;
}

.pond-tab {
  height: 64rpx;
  border-radius: 8rpx;
  background: #fffaf3;
  color: #7d6252;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.pond-tab.active {
  background: #fff0dc;
  color: #b65f2a;
}

.pond-empty {
  padding: 18rpx 24rpx 30rpx;
  color: #8a7467;
  font-size: 25rpx;
  line-height: 1.5;
}

.pond-item {
  min-height: 104rpx;
  padding: 18rpx 24rpx;
  border-top: 2rpx solid #f2e4d6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.pond-item-title {
  display: block;
  color: #3a2a22;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.pond-item-meta {
  display: block;
  margin-top: 7rpx;
  color: #9b8475;
  font-size: 22rpx;
  line-height: 1.35;
}

.pond-item-arrow {
  flex: 0 0 auto;
  color: #b9a69a;
  font-size: 42rpx;
}

.pond-item-actions {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pond-delete {
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  color: #b65f2a;
  background: #fff0dc;
  font-size: 22rpx;
  font-weight: 800;
}

.badge-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.badge-card {
  min-height: 170rpx;
  padding: 20rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 12rpx 30rpx rgba(118, 82, 55, 0.05);
  text-align: center;
  box-sizing: border-box;
}

.badge-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin: 0 auto 12rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  font-size: 24rpx;
  font-weight: 800;
}

.badge-title {
  display: block;
  color: #3a2a22;
  font-size: 24rpx;
  font-weight: 800;
}

.badge-desc {
  display: block;
  margin-top: 8rpx;
  color: #8a7467;
  font-size: 21rpx;
  line-height: 1.35;
}

.future-card {
  margin-top: 30rpx;
  padding: 30rpx;
  border-radius: 8rpx;
  color: #3a2a22;
  background: linear-gradient(135deg, #fff0dc 0%, #eadcf8 52%, #dfe9bf 100%);
  box-shadow: 0 18rpx 42rpx rgba(118, 82, 55, 0.08);
}

.future-kicker {
  display: block;
  color: #8c5a3d;
  font-size: 23rpx;
  font-weight: 800;
}

.future-title {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.future-desc {
  display: block;
  margin-top: 10rpx;
  color: #6b5a50;
  font-size: 26rpx;
  line-height: 1.55;
}
