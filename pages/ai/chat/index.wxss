.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: 22rpx;
}

.chat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 26rpx 28rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #fff0dc 0%, #f7d4b6 52%, #dfe9bf 100%);
  color: #3a2a22;
  box-shadow: 0 18rpx 42rpx rgba(118, 82, 55, 0.08);
}

.chat-title {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
}

.status-pill {
  padding: 10rpx 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.68);
  color: #b65f2a;
  font-size: 24rpx;
  font-weight: 700;
}

.message-list {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 6rpx 2rpx 18rpx;
}

.message {
  max-width: 82%;
  margin-bottom: 22rpx;
  padding: 22rpx 26rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
  box-shadow: 0 14rpx 34rpx rgba(16, 24, 40, 0.06);
}

.message.assistant {
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  color: #5f4b3f;
  border-top-left-radius: 2rpx;
}

.message.user {
  margin-left: auto;
  background: linear-gradient(135deg, #d97745 0%, #b65f2a 100%);
  color: #ffffff;
  border-top-right-radius: 2rpx;
}

.composer {
  display: grid;
  grid-template-columns: 1fr 144rpx;
  gap: 16rpx;
  align-items: end;
  padding: 18rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 15rpx 36rpx rgba(118, 82, 55, 0.07);
}

.composer-input {
  min-height: 84rpx;
  max-height: 220rpx;
  border: 2rpx solid #ead9c9;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #3a2a22;
}

.send-button {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(182, 95, 42, 0.18);
}
