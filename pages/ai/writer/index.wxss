.form-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 38rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #3a2a22;
}

.input {
  margin-bottom: 18rpx;
}

.picker {
  height: 82rpx;
  padding: 0 24rpx;
  border: 2rpx solid #ead9c9;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #5f4b3f;
  font-size: 28rpx;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.result-meta {
  margin-top: 24rpx;
  color: #b65f2a;
  font-size: 24rpx;
  font-weight: 700;
}

.result-box {
  min-height: 280rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  border-radius: 8rpx;
  padding: 30rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #5f4b3f;
  white-space: pre-wrap;
  box-shadow: 0 15rpx 36rpx rgba(118, 82, 55, 0.07);
}
