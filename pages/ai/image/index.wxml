<view class="page">
  <view class="panel">
    <text class="eyebrow">Image Prompt</text>
    <text class="form-title">把想法变成图片提示词</text>
    <textarea class="textarea" placeholder="例如：一个面向创业者的 AI 工具平台封面" value="{{prompt}}" bindinput="onInput" maxlength="500" />
    <button class="primary-button" loading="{{loading}}" bindtap="createIdea">生成提示词</button>
  </view>

  <view class="section-head">
    <text class="section-title">提示词</text>
    <text class="result-meta">{{result ? "可复制使用" : "等待生成"}}</text>
  </view>
  <view class="prompt-box">
    <text>{{result || "这里先生成可用于图片模型的提示词。后续可以接入图片生成 API，直接返回图片。"}}</text>
  </view>
</view>
