.today-page {
  padding-bottom: 72rpx;
}

.dashboard {
  position: relative;
  overflow: hidden;
  min-height: 390rpx;
  border-radius: 8rpx;
  padding: 38rpx;
  box-sizing: border-box;
  color: #3a2a22;
  background: linear-gradient(135deg, #fff0dc 0%, #f8cfa9 48%, #dcefc9 100%);
  box-shadow: 0 26rpx 64rpx rgba(177, 112, 62, 0.18);
}

.dashboard-rain {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
}

.dashboard-coin,
.dashboard-bill {
  position: absolute;
  top: -60rpx;
  color: #9a5a1f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  opacity: 0;
  box-shadow: 0 8rpx 16rpx rgba(151, 92, 52, 0.12);
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.dashboard-coin {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #fff7bf 0%, #f8c66a 50%, #d99a2b 100%);
  border: 3rpx solid rgba(255, 244, 186, 0.9);
  font-size: 22rpx;
  animation-name: dashboardCoinFall;
}

.dashboard-bill {
  width: 78rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: linear-gradient(145deg, #e9f8d5 0%, #b9dc8b 100%);
  border: 3rpx solid rgba(255, 255, 255, 0.72);
  color: #5f7f39;
  font-size: 20rpx;
  animation-name: dashboardBillFall;
}

.dashboard-coin.one {
  left: 8%;
  animation-duration: 4s;
  animation-delay: 0s;
}

.dashboard-bill.two {
  left: 23%;
  animation-duration: 4.8s;
  animation-delay: 0.7s;
}

.dashboard-coin.three {
  left: 42%;
  animation-duration: 4.2s;
  animation-delay: 1.3s;
}

.dashboard-bill.four {
  left: 60%;
  animation-duration: 5.1s;
  animation-delay: 0.35s;
}

.dashboard-coin.five {
  left: 76%;
  animation-duration: 4.5s;
  animation-delay: 1.8s;
}

.dashboard-bill.six {
  left: 88%;
  animation-duration: 5.4s;
  animation-delay: 1.1s;
}

@keyframes dashboardBillFall {
  0% {
    transform: translateY(-80rpx) rotate(-16deg);
    opacity: 0;
  }

  12% {
    opacity: 0.8;
  }

  50% {
    transform: translateY(210rpx) rotate(12deg);
  }

  88% {
    opacity: 0.8;
  }

  100% {
    transform: translateY(510rpx) rotate(-28deg);
    opacity: 0;
  }
}

@keyframes dashboardCoinFall {
  0% {
    transform: translateY(-70rpx) rotate(0deg);
    opacity: 0;
  }

  12% {
    opacity: 0.86;
  }

  88% {
    opacity: 0.86;
  }

  100% {
    transform: translateY(500rpx) rotate(220deg);
    opacity: 0;
  }
}

.dashboard-copy {
  position: relative;
  z-index: 1;
}

.light {
  color: #b65f2a;
}

.dashboard-title {
  display: block;
  max-width: 430rpx;
  font-size: 50rpx;
  line-height: 1.18;
  font-weight: 800;
}

.dashboard-subtitle {
  display: block;
  margin-top: 18rpx;
  max-width: 430rpx;
  color: #7d6252;
  font-size: 27rpx;
  line-height: 1.55;
}

.money-card {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  padding: 26rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.68);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  box-shadow: 0 14rpx 34rpx rgba(151, 92, 52, 0.08);
}

.money-label,
.money-rate {
  display: block;
  color: #8c5a3d;
  font-size: 24rpx;
  font-weight: 700;
}

.money-value {
  display: block;
  margin: 8rpx 0;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 800;
  color: #a75225;
}

.progress-panel,
.after-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(118, 82, 55, 0.07);
}

.progress-head,
.progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #8a7467;
}

.progress-head {
  color: #3a2a22;
  font-size: 26rpx;
  font-weight: 700;
}

.progress-track {
  height: 18rpx;
  margin: 22rpx 0 14rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #f2e4d6;
}

.progress-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #f4a261 0%, #d97745 46%, #8fbf78 100%);
}

.home-pet {
  position: fixed;
  width: 166rpx;
  height: 196rpx;
  z-index: 20;
  perspective: 680rpx;
  transform-style: preserve-3d;
  animation-name: homePetFloat;
  animation-duration: 3s;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
}

.home-pet.play {
  animation-name: homePetPop;
  animation-duration: 0.9s;
  animation-iteration-count: 1;
}

.home-pet.dragging {
  animation-name: none;
  transform: rotateY(-14deg) translateZ(18rpx) scale(1.05);
}

.home-pet-bubble {
  position: absolute;
  top: -42rpx;
  right: -18rpx;
  left: -18rpx;
  padding: 12rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.94);
  border: 2rpx solid rgba(234, 217, 201, 0.92);
  box-shadow: 0 12rpx 26rpx rgba(118, 82, 55, 0.1);
  color: #6c5142;
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 700;
  text-align: center;
}

.home-pet-bubble::after {
  content: "";
  position: absolute;
  right: 72rpx;
  bottom: -10rpx;
  width: 18rpx;
  height: 18rpx;
  border-right: 2rpx solid rgba(234, 217, 201, 0.92);
  border-bottom: 2rpx solid rgba(234, 217, 201, 0.92);
  background: rgba(255, 253, 249, 0.94);
  transform: rotate(45deg);
}

.home-pet-shadow {
  position: absolute;
  left: 20rpx;
  bottom: 2rpx;
  width: 126rpx;
  height: 28rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center, rgba(69, 48, 37, 0.22) 0%, rgba(69, 48, 37, 0.1) 48%, rgba(69, 48, 37, 0) 74%);
  transform: translateZ(-44rpx) rotateX(72deg);
  animation-name: homePetShadow;
  animation-duration: 3s;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
}

.home-pet-tail {
  position: absolute;
  right: 8rpx;
  top: 86rpx;
  width: 52rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 28% 24%, #f2bf8b 0%, #c17a4a 62%, #75513f 100%);
  box-shadow: inset -8rpx -8rpx 14rpx rgba(87, 55, 38, 0.2);
  transform: translateZ(-20rpx) rotate(24deg);
  transform-origin: 10rpx 30rpx;
  animation-name: homeTailWag;
  animation-duration: 1.15s;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
}

.home-pet-body {
  position: absolute;
  left: 36rpx;
  bottom: 26rpx;
  width: 94rpx;
  height: 68rpx;
  border-radius: 48% 48% 42% 42%;
  background: radial-gradient(circle at 32% 18%, #c9efab 0%, #8fbf78 46%, #5c934e 100%);
  box-shadow: inset -12rpx -14rpx 20rpx rgba(54, 84, 43, 0.22), inset 8rpx 8rpx 14rpx rgba(255, 255, 255, 0.22), 0 10rpx 18rpx rgba(84, 116, 66, 0.16);
  transform: translateZ(12rpx);
  transform-style: preserve-3d;
  z-index: 2;
}

.home-pet-belly {
  position: absolute;
  left: 26rpx;
  top: 18rpx;
  width: 42rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(246, 247, 216, 0.66);
}

.home-pet-foot {
  position: absolute;
  bottom: -8rpx;
  width: 32rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #6f9f72;
  box-shadow: inset -5rpx -4rpx 8rpx rgba(52, 82, 46, 0.2);
}

.home-pet-foot.left {
  left: 10rpx;
}

.home-pet-foot.right {
  right: 10rpx;
}

.home-pet-ear {
  position: absolute;
  top: 16rpx;
  width: 50rpx;
  height: 56rpx;
  border-radius: 48% 48% 40% 40%;
  background: linear-gradient(145deg, #936b53 0%, #684735 100%);
  box-shadow: inset -7rpx -8rpx 12rpx rgba(50, 31, 23, 0.24), 0 7rpx 10rpx rgba(78, 48, 35, 0.1);
  z-index: 3;
}

.home-pet-ear.left {
  left: 34rpx;
  transform: translateZ(18rpx) rotate(-20deg) rotateY(-12deg);
}

.home-pet-ear.right {
  right: 34rpx;
  transform: translateZ(18rpx) rotate(20deg) rotateY(12deg);
}

.home-pet-ear-inner {
  position: absolute;
  top: 12rpx;
  left: 10rpx;
  width: 30rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(255, 205, 174, 0.54);
}

.home-pet-face {
  position: absolute;
  top: 44rpx;
  left: 25rpx;
  width: 116rpx;
  height: 104rpx;
  border-radius: 46% 46% 42% 42%;
  background: radial-gradient(circle at 34% 20%, #fff9df 0%, #f6c895 44%, #d8945f 100%);
  border: 4rpx solid #73513e;
  box-sizing: border-box;
  box-shadow: inset -11rpx -14rpx 20rpx rgba(117, 70, 45, 0.18), inset 9rpx 8rpx 13rpx rgba(255, 255, 255, 0.28), 0 12rpx 18rpx rgba(117, 70, 45, 0.16);
  transform: translateZ(36rpx) rotateX(-2deg);
  z-index: 4;
}

.home-pet-eye {
  position: absolute;
  top: 38rpx;
  width: 12rpx;
  height: 17rpx;
  border-radius: 50%;
  background: #3d2b24;
  box-shadow: 3rpx 3rpx 0 rgba(255, 255, 255, 0.35) inset;
  animation-name: homePetBlink;
  animation-duration: 4.2s;
  animation-iteration-count: infinite;
}

.home-pet-eye.left {
  left: 32rpx;
}

.home-pet-eye.right {
  right: 32rpx;
}

.home-pet-nose {
  position: absolute;
  left: 52rpx;
  top: 56rpx;
  width: 12rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #5f3f32;
}

.home-pet-mouth {
  position: absolute;
  left: 49rpx;
  top: 66rpx;
  width: 18rpx;
  height: 8rpx;
  border-bottom: 4rpx solid #5f3f32;
  border-radius: 50%;
}

.home-pet-blush {
  position: absolute;
  top: 64rpx;
  width: 16rpx;
  height: 9rpx;
  border-radius: 50%;
  background: rgba(214, 116, 82, 0.3);
  box-shadow: 0 0 6rpx rgba(214, 116, 82, 0.12);
}

.home-pet-blush.left {
  left: 18rpx;
}

.home-pet-blush.right {
  right: 18rpx;
}

.home-pet-arm {
  position: absolute;
  top: 112rpx;
  width: 26rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(155deg, #f2bf8b 0%, #bd7d50 100%);
  box-shadow: inset -6rpx -7rpx 10rpx rgba(90, 55, 39, 0.18);
  z-index: 5;
}

.home-pet-arm.left {
  left: 24rpx;
  transform: translateZ(42rpx) rotate(16deg);
  animation-name: homeArmWaveLeft;
  animation-duration: 1.7s;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
}

.home-pet-arm.right {
  right: 24rpx;
  transform: translateZ(42rpx) rotate(-16deg);
  animation-name: homeArmWaveRight;
  animation-duration: 1.7s;
  animation-delay: 0.18s;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
}

@keyframes homePetFloat {
  0%,
  100% {
    transform: translateY(0) rotateY(-8deg) rotateZ(-1deg);
  }

  50% {
    transform: translateY(-12rpx) rotateY(8deg) rotateZ(2deg);
  }
}

@keyframes homePetPop {
  0%,
  100% {
    transform: translateY(0) rotateY(0deg) scale(1);
  }

  35% {
    transform: translateY(-32rpx) rotateY(-18deg) scale(1.08, 0.94);
  }

  68% {
    transform: translateY(4rpx) rotateY(14deg) scale(0.95, 1.06);
  }
}

@keyframes homePetShadow {
  0%,
  100% {
    transform: translateZ(-44rpx) rotateX(72deg) scale(1);
    opacity: 0.82;
  }

  50% {
    transform: translateZ(-44rpx) rotateX(72deg) scale(0.78);
    opacity: 0.45;
  }
}

@keyframes homeTailWag {
  0%,
  100% {
    transform: translateZ(-20rpx) rotate(18deg);
  }

  50% {
    transform: translateZ(-20rpx) rotate(40deg);
  }
}

@keyframes homeArmWaveLeft {
  0%,
  100% {
    transform: translateZ(42rpx) rotate(12deg);
  }

  50% {
    transform: translateZ(46rpx) rotate(30deg) translateY(-4rpx);
  }
}

@keyframes homeArmWaveRight {
  0%,
  100% {
    transform: translateZ(42rpx) rotate(-12deg);
  }

  50% {
    transform: translateZ(46rpx) rotate(-30deg) translateY(-4rpx);
  }
}

@keyframes homePetBlink {
  0%,
  92%,
  100% {
    transform: scaleY(1);
  }

  95% {
    transform: scaleY(0.12);
  }
}

.growth-panel,
.wish-panel,
.mystic-panel {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 16rpx 38rpx rgba(118, 82, 55, 0.07);
}

.growth-panel {
  background: linear-gradient(135deg, #fff7e8 0%, #f7f8e8 100%);
  border-color: rgba(223, 233, 191, 0.92);
}

.growth-kicker,
.panel-kicker {
  display: block;
  color: #b65f2a;
  font-size: 23rpx;
  font-weight: 800;
}

.growth-title,
.panel-title {
  display: block;
  margin-top: 10rpx;
  color: #3a2a22;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.growth-desc {
  display: block;
  margin-top: 10rpx;
  color: #7d6252;
  font-size: 25rpx;
  line-height: 1.5;
}

.growth-meter {
  height: 18rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: rgba(242, 228, 214, 0.9);
}

.growth-fill {
  height: 100%;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #8fbf78 0%, #f4a261 100%);
}

.growth-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 12rpx;
  color: #8a7467;
  font-size: 23rpx;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.panel-tag {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  font-size: 22rpx;
  font-weight: 800;
}

.wish-input-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 22rpx;
}

.wish-input {
  flex: 1;
  height: 78rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: #fffaf3;
  border: 2rpx solid #ead9c9;
  color: #3a2a22;
  font-size: 25rpx;
}

.wish-button {
  flex: 0 0 132rpx;
  height: 78rpx;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.wish-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.wish-empty {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #fff7ee;
  border: 2rpx dashed rgba(182, 95, 42, 0.24);
}

.wish-empty-title {
  display: block;
  color: #7d4b30;
  font-size: 26rpx;
  font-weight: 800;
}

.wish-empty-desc {
  display: block;
  margin-top: 8rpx;
  color: #8a7467;
  font-size: 24rpx;
  line-height: 1.5;
}

.wish-chip {
  max-width: 100%;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #7d4b30;
  font-size: 23rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.wish-delete {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(122, 90, 71, 0.12);
  color: #8a7467;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.wish-share,
.wish-meetup {
  padding: 5rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #b65f2a;
  font-size: 21rpx;
  font-weight: 800;
}

.wish-meetup {
  color: #3f6f64;
}

.mystic-panel {
  background: linear-gradient(135deg, #fff7ec 0%, #eef4da 100%);
}

.mystic-empty {
  margin-top: 22rpx;
  color: #7d6252;
  font-size: 25rpx;
  line-height: 1.5;
}

.mystic-button {
  height: 76rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  background: #b65f2a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}

.mystic-action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.mystic-button.secondary {
  background: #fff0dc;
  color: #b65f2a;
  border: 2rpx solid #f3caa6;
}

.mystic-result {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: rgba(255, 253, 249, 0.86);
  border: 2rpx solid rgba(234, 217, 201, 0.76);
}

.mystic-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.mystic-level {
  padding: 7rpx 13rpx;
  border-radius: 8rpx;
  background: #dfe9bf;
  color: #627a35;
  font-size: 22rpx;
  font-weight: 800;
}

.mystic-title {
  color: #3a2a22;
  font-size: 31rpx;
  font-weight: 800;
}

.mystic-desc,
.mystic-line {
  display: block;
  margin-top: 14rpx;
  color: #6b5a50;
  font-size: 25rpx;
  line-height: 1.5;
}

.mystic-line {
  margin-top: 10rpx;
  font-weight: 800;
}

.muted-line {
  color: #9b8475;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.quick-card {
  min-height: 190rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  background: rgba(255, 253, 249, 0.96);
  border: 2rpx solid rgba(234, 217, 201, 0.78);
  box-shadow: 0 14rpx 34rpx rgba(118, 82, 55, 0.06);
}

.quick-card.primary {
  background: #fff0dc;
  color: #3a2a22;
  border-color: #f3caa6;
}

.quick-card.warm {
  background: #f7f8e8;
  border-color: #dfe9bf;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  font-size: 26rpx;
  font-weight: 800;
}

.primary .quick-icon {
  background: #f7d4b6;
  color: #8c461f;
}

.warm .quick-icon {
  background: #dfe9bf;
  color: #627a35;
}

.quick-title {
  display: block;
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
}

.quick-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #8a7467;
}

.primary .quick-desc {
  color: #7d6252;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-action {
  margin-top: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #fff0dc;
  color: #b65f2a;
  font-size: 22rpx;
  font-weight: 800;
}

.after-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 0;
}

.after-title {
  display: block;
